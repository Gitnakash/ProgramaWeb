#subB1 {
    margin: 15px ;
    width: auto;
    height: 90%;
    
    
}
#img1 {
    width: auto;
    height: 100%;
    border-radius: 20px;
}

#subB2 {
    margin: 15px;
    width: 50%;
    height: 90%;
    display: flex;
    flex-direction: column;
    
}


.ss1 {
    margin: 5px;
    background-color: rgb(255, 255, 255);
    height: 14.5%;
    border-radius: 15px;
    display: flex;
    flex-direction: row;
    align-items: center;
    font-family: Arial;
    font-size: 20px;
}
